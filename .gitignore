# =============================================================================
# Jal-Prahari — .gitignore
# =============================================================================

# ─── SECRETS — Critical: never commit real credentials ───────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
*.crt
secrets/

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
venv/
env/
.venv/
.env/
ENV/

# Testing & coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# ─── Node.js / React ─────────────────────────────────────────────────────────
node_modules/
dist/
.next/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm

# ─── Docker ──────────────────────────────────────────────────────────────────
# Local override files — safe to ignore, not production config
docker-compose.override.yml

# ─── IDEs & Editors ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Jupyter ─────────────────────────────────────────────────────────────────
.ipynb_checkpoints
*.ipynb_checkpoints

# ─── Data & ML artifacts ─────────────────────────────────────────────────────
*.h5
*.pkl
*.joblib
*.npy
*.npz
data/raw/
data/processed/
models/weights/

# ─── GIS / Geospatial ────────────────────────────────────────────────────────
*.tif
*.tiff
*.shp
*.dbf
*.shx
*.prj
*.geojson.bak
