# =============================================================================
# Jal-Prahari — Environment Variable Template
# =============================================================================
#
# INSTRUCTIONS
# ─────────────
# 1. Copy this file to .env:
#       cp .env.example .env          (Linux/macOS)
#       copy .env.example .env        (Windows)
#
# 2. Fill in real values in .env.
#
# 3. NEVER commit .env to version control.
#    The .gitignore already excludes it — verify with: git status
#
# WHY SECRETS MUST NOT BE COMMITTED
# ─────────────────────────────────────────────────────────────────────────────
# • Git history is permanent. Even if you delete a secret in a later commit,
#   it remains visible in every earlier commit and in every clone/fork.
# • Public repositories are scanned by automated bots within seconds of push.
# • Secret exposure can result in unauthorized database dumps, ransomware,
#   GDPR violations, and financial liability.
# • Use tools like `git-secrets`, `truffleHog`, or GitHub Secret Scanning
#   to detect accidental leaks before they reach the remote.
#
# SAFE ALTERNATIVES TO HARDCODING
# ─────────────────────────────────────────────────────────────────────────────
# • Local development  : .env file (git-ignored)
# • CI/CD pipelines    : GitHub Actions Secrets / GitLab CI Variables
# • Docker Compose     : env_file directive + Docker Secrets
# • Kubernetes         : Secret objects, mounted as env vars or files
# • Production cloud   : AWS Secrets Manager, GCP Secret Manager, HashiCorp Vault
# =============================================================================


# ─── PostgreSQL / PostGIS ─────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=jal_prahari
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ─── Application ─────────────────────────────────────────────────────────────
# Controls SQLAlchemy query echo. Set to DEBUG to see all generated SQL.
LOG_LEVEL=INFO

# ─── Future placeholders ─────────────────────────────────────────────────────
# BACKEND_CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
# MAPBOX_ACCESS_TOKEN=pk.your_mapbox_public_token_here
# SECRET_KEY=generate_with_openssl_rand_hex_32
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30
