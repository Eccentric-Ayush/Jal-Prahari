# ==============================================================================
# JAL-PRAHARI BACKEND - PRODUCTION ENVIRONMENT CONFIGURATION
# ==============================================================================
# WARNING: This is an example file. Never commit real secrets to version control.
# In Railway, these variables will be injected automatically or configured
# via the Railway Dashboard (Variables tab).
# ==============================================================================

# Application Environment
APP_ENV=production
LOG_LEVEL=INFO

# Database Connection (Injected by Railway PostgreSQL service if linked)
DATABASE_URL=postgresql+psycopg2://postgres:yourpassword@containers-us-west-111.railway.app:5432/railway

# Optional explicit DB params if DATABASE_URL is not used directly
POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpassword
POSTGRES_DB=railway
POSTGRES_HOST=containers-us-west-111.railway.app
POSTGRES_PORT=5432

# Cross-Origin Resource Sharing (CORS)
# Add your production frontend URL here. Separate multiple domains with commas.
# Ensure no trailing slashes.
ALLOWED_ORIGINS=https://jal-prahari.vercel.app

# Security
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY=replace_with_a_highly_secure_random_string_for_production
