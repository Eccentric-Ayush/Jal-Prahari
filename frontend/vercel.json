{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://jal-prahari-api.up.railway.app/api/$1"
    },
    {
      "source": "/ws/(.*)",
      "destination": "https://jal-prahari-api.up.railway.app/ws/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
