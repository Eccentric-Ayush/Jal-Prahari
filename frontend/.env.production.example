# ==============================================================================
# JAL-PRAHARI FRONTEND - PRODUCTION ENVIRONMENT CONFIGURATION
# ==============================================================================
# WARNING: This is an example file. Never commit real keys to version control.
# In Vercel, these variables will be injected via the Project Settings -> Environment Variables.
# ==============================================================================

# MapTiler API Key for production map tiles
VITE_MAPTILER_KEY=your_production_maptiler_key_here

# Backend API Base URL
# Point this to your Railway production URL. 
# Do not include a trailing slash.
VITE_API_BASE_URL=https://jal-prahari-api.railway.app
